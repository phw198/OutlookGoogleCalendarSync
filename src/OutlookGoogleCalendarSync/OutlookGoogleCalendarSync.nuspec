        <file src="bin\Release-v3\logger.xml" target="lib\net45\" />
        <file src="bin\Release-v3\tzdb.nzd" target="lib\net45\" />
        <file src="bin\Release-v3\Console\*.*" target="lib\net45\Console\" />
        <file src="bin\Release-v3\Console\emoji\*.*" target="lib\net45\Console\emoji\" />
  </files>
</package>